{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FleetScout Driver State Contract",
  "description": "Explicit string contract definitions for localized single-tenant driver states.",
  "type": "object",
  "required": ["driver_id", "current_state", "timestamp"],
  "properties": {
    "driver_id": {
      "type": "string"
    },
    "current_state": {
      "type": "string",
      "enum": ["Available", "On Route", "On Break", "Off Duty"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
